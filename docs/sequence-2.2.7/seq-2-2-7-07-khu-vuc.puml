' 2.2.7.7 — Khu vuc: danh sach (co dem phong) va them moi
@startuml seq-2-2-7-07-khu-vuc
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true
skinparam ParticipantPadding 20
title 2.2.7.7 — Quan ly khu vuc (GET co DTO, POST)
actor "Admin - Staff" as A
participant "Trang khu vuc" as FE <<boundary>>
participant "KhuVucController" as KC <<control>>
participant "KhuVucRepository" as KR <<control>>
participant "PhongRepository" as PR <<control>>
participant "HopDongRepository" as HR <<control>>

A -> FE : mo trang khu vuc
FE -> KC : GET /api/khu-vuc
activate KC
KC -> KR : findAll()
activate KR
KR --> KC : List KhuVuc
deactivate KR
KC -> PR : countByKhuVuc_Id (tung khu)
KC -> HR : countByPhong_KhuVuc_IdAndTrangThai(ACTIVE)
KC --> FE : List AreaWithRoomCountDto
deactivate KC

A -> FE : them khu (Admin)
FE -> KC : POST /api/khu-vuc\n(KhuVuc JSON)
activate KC
KC -> KR : save(khuVuc)
activate KR
KR --> KC : KhuVuc
deactivate KR
KC --> FE : 200 + KhuVuc
deactivate KC
@enduml
