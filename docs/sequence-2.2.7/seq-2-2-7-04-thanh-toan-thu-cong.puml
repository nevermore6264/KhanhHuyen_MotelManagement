activate TTR
TTR --> TTC : ThanhToan daLuu
deactivate TTR
TTC -> TTR : findByHoaDonId(hoaDonId)
activate TTR
TTR --> TTC : List ThanhToan
deactivate TTR
TTC -> TTC : tong tien da tra >= tong tien HD?
TTC -> HDR : "save(hoaDon) PAID hoac PARTIAL"
activate HDR
HDR --> TTC
deactivate HDR
TTC --> FE : 200 + ThanhToan
deactivate TTC
