' 2.2.7.15 — Cap nhat trang thai hoa don
@startuml seq-2-2-7-15-hoa-don-cap-nhat-trang-thai
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true
skinparam ParticipantPadding 20
title 2.2.7.15 — Cap nhat trang thai hoa don
actor "Admin - Staff" as S
participant "Trang hoa don" as FE <<boundary>>
participant "HoaDonController" as HDC <<control>>
participant "HoaDonRepository" as HDR <<control>>

S -> FE : doi trang thai (UNPAID, PAID, ...)
FE -> HDC : PUT /api/hoa-don/{id}/trang-thai?status=...
activate HDC
HDC -> HDR : findById, setTrangThai, save
activate HDR
HDR --> HDC : HoaDon
deactivate HDR
HDC --> FE : 200
deactivate HDC
@enduml
