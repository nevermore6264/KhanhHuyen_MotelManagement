' 2.2.7.11 — Hop dong: Admin tao hop dong, cap nhat phong OCCUPIED
@startuml seq-2-2-7-11-hop-dong-admin-tao
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true
skinparam ParticipantPadding 20
title 2.2.7.11 — Tao hop dong (Admin)
actor "Admin" as A
participant "Trang hop dong" as FE <<boundary>>
participant "HopDongController" as HC <<control>>
participant "PhongRepository" as PR <<control>>
participant "KhachThueRepository" as KTR <<control>>
participant "HopDongRepository" as HopR <<control>>

A -> FE : chon phong, khach, ngay, tien
FE -> HC : POST /api/hop-dong\n(HopDong JSON)
activate HC
HC -> PR : findById(phongId)
HC -> KTR : findById(khachThueId)
HC -> HopR : save(hopDong)
activate HopR
HopR --> HC : HopDong
deactivate HopR
HC -> PR : phong.setTrangThai(OCCUPIED)\nphongRepository.save
HC --> FE : 200 + HopDong
deactivate HC
@enduml
