' 2.2.7.5 — Quen mat khau va dat lai (token)
@startuml seq-2-2-7-05-dat-lai-mat-khau
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true
skinparam ParticipantPadding 20
title 2.2.7.5 — Quen mat khau va dat lai mat khau (token)
actor "Nguoi dung" as U
participant "Trang web" as FE <<boundary>>
participant "XacThucController" as XC <<control>>
participant "XacThucService" as XS <<control>>
participant "NguoiDungRepository" as NR <<control>>
participant "PhieuDatLaiMatKhauRepository" as PR <<control>>

U -> FE : yeu cau quen mat khau
FE -> XC : POST /api/xac-thuc/quen-mat-khau
activate XC
XC -> XS : quenMatKhau(yeuCau)
activate XS
XS -> NR : findByTenDangNhap(...)
XS -> PR : xoaTheoMaNguoiDung(userId)
XS -> PR : save(PhieuDatLaiMatKhau)
XS --> XC : PhanHoiQuenMatKhau (+ email - link)
deactivate XS
deactivate XC

U -> FE : mo link + mat khau moi
FE -> XC : POST /api/xac-thuc/dat-lai-mat-khau
activate XC
XC -> XS : datLaiMatKhau(yeuCau)
activate XS
XS -> PR : findByMaToken(token)
XS -> XS : phieu.daHetHan() ?
XS -> NR : save(NguoiDung) mat khau moi
XS -> PR : delete(phieu)
deactivate XS
deactivate XC
@enduml
