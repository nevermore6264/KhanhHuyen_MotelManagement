' 2.2.7.12 — Tenant xem hop dong cua minh
@startuml seq-2-2-7-12-hop-dong-cua-toi
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true
skinparam ParticipantPadding 20
title 2.2.7.12 — Hop dong cua toi (Tenant)
actor "Khach thue" as T
participant "Trang hop dong cua toi" as FE <<boundary>>
participant "HopDongController" as HC <<control>>
participant "NguoiDungHienTaiService" as ND <<control>>
participant "KhachThueRepository" as KTR <<control>>
participant "HopDongRepository" as HopR <<control>>

T -> FE : xem danh sach hoac chi tiet
FE -> HC : GET /api/hop-dong/cua-toi
activate HC
HC -> ND : layNguoiDungHienTai()
HC -> KTR : findByNguoiDung_Id
HC -> HopR : findByKhachThue_Id
HopR --> HC : List HopDong
HC --> FE : JSON
deactivate HC

FE -> HC : GET /api/hop-dong/cua-toi/{id}
activate HC
HC -> HopR : findById + filter khach
HC --> FE : HopDong hoac 404
deactivate HC
@enduml
