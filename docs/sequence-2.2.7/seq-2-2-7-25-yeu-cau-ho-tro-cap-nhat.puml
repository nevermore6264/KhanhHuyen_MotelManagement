' 2.2.7.25 — Staff xem va cap nhat yeu cau ho tro
@startuml seq-2-2-7-25-yeu-cau-ho-tro-cap-nhat
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true
skinparam ParticipantPadding 20
title 2.2.7.25 — Xem - cap nhat yeu cau ho tro (Staff)
actor "Admin - Staff" as S
participant "Trang yeu cau ho tro" as FE <<boundary>>
participant "YeuCauHoTroController" as YC <<control>>
participant "YeuCauHoTroRepository" as YR <<control>>

S -> FE : mo danh sach
FE -> YC : GET /api/yeu-cau-ho-tro
activate YC
YC -> YR : findAll()
activate YR
YR --> YC : List
deactivate YR
YC --> FE : JSON
deactivate YC

S -> FE : doi trang thai - noi dung
FE -> YC : PUT /api/yeu-cau-ho-tro/{id}
activate YC
YC -> YR : findById, merge, setNgayCapNhat, save
activate YR
YR --> YC : YeuCauHoTro
deactivate YR
YC --> FE : 200
deactivate YC
@enduml
