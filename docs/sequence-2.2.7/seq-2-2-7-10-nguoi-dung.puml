' 2.2.7.10 — Nguoi dung: Admin tao tai khoan
@startuml seq-2-2-7-10-nguoi-dung
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true
skinparam ParticipantPadding 20
title 2.2.7.10 — Quan ly nguoi dung (Admin tao user)
actor "Admin" as A
participant "Trang nguoi dung" as FE <<boundary>>
participant "NguoiDungController" as NC <<control>>
participant "PasswordEncoder" as PE <<control>>
participant "NguoiDungRepository" as NR <<control>>
participant "KhachThueRepository" as KTR <<control>>

A -> FE : tao STAFF hoac TENANT
FE -> NC : POST /api/nguoi-dung\n(YeuCauTaoNguoiDung)
activate NC
NC -> PE : encode(matKhau)
NC -> NR : save(NguoiDung)
activate NR
NR --> NC : NguoiDung daLuu
deactivate NR
NC -> KTR : save lien ket KhachThue neu maKhachThue + TENANT
activate KTR
deactivate KTR
NC --> FE : 200 + NguoiDung
deactivate NC
@enduml
