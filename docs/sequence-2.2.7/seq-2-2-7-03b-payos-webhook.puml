' 2.2.7.3b — Webhook PayOS (xac nhan thanh toan)
@startuml seq-2-2-7-03b-payos-webhook
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true
skinparam ParticipantPadding 20
title 2.2.7.3b — Webhook PayOS (xac nhan thanh toan)
participant "PayOS" as PAY <<boundary>>
participant "ThanhToanController" as TTC <<control>>
participant "PayOSService" as POS <<control>>
participant "DonHangPayOSRepository" as DHR <<control>>
participant "HoaDonRepository" as HDR <<control>>
participant "ThanhToanRepository" as TTR <<control>>

PAY -> TTC : POST /api/thanh-toan/payos/webhook\n(body JSON)
activate TTC
TTC -> POS : xacThucVaXuLyWebhook(noiDungYeuCau)
activate POS
POS -> POS : verify signature, parse data
POS -> DHR : findByMaDonHang(orderCode)
activate DHR
DHR --> POS : Optional DonHangPayOS
deactivate DHR
POS -> HDR : findById(maHoaDon)
activate HDR
HDR --> POS : HoaDon
deactivate HDR
POS -> TTR : save(ThanhToan)
activate TTR
TTR --> POS
deactivate TTR
POS -> TTR : findByHoaDonId (tong hop so tien)
POS -> HDR : save(hoaDon) cap nhat PAID/PARTIAL
activate HDR
HDR --> POS
deactivate HDR
POS -> DHR : delete(donHang)
activate DHR
deactivate DHR
POS --> TTC : boolean
deactivate POS
TTC --> PAY : "HTTP 200 hoac 400"
deactivate TTC
@enduml
