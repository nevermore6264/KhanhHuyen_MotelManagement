' 2.2.7.14 — Tenant xem hoa don cua minh
@startuml seq-2-2-7-14-hoa-don-cua-toi
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true
skinparam ParticipantPadding 20
title 2.2.7.14 — Hoa don cua toi (Tenant)
actor "Khach thue" as T
participant "Trang hoa don cua toi" as FE <<boundary>>
participant "HoaDonController" as HDC <<control>>
participant "NguoiDungHienTaiService" as ND <<control>>
participant "KhachThueRepository" as KTR <<control>>
participant "HoaDonRepository" as HDR <<control>>

T -> FE : xem hoa don
FE -> HDC : GET /api/hoa-don/cua-toi
activate HDC
HDC -> ND : layNguoiDungHienTai()
HDC -> KTR : findByNguoiDung_Id
HDC -> HDR : findByKhachThue(khachThue)
activate HDR
HDR --> HDC : List HoaDon
deactivate HDR
HDC --> FE : JSON
deactivate HDC
@enduml
