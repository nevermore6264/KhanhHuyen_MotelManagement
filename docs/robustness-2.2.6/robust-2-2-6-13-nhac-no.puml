' 2.2.6.13 — Nhac no hoa don
@startuml robust-2-2-6-13-nhac-no
allowmixing
skinparam shadowing false
skinparam roundcorner 8
skinparam class {
  BackgroundColor<<boundary>> #E8F5E9
  BorderColor<<boundary>> #2E7D32
  BackgroundColor<<control>> #FFFDE7
  BorderColor<<control>> #F9A825
  BackgroundColor<<entity>> #FCE4EC
  BorderColor<<entity>> #C2185B
  FontSize 13
}
skinparam ArrowColor #37474F
skinparam ActorBorderColor #1565C0
skinparam ActorBackgroundColor #E3F2FD

title 2.2.6.13 — Gui nhac no hoa don
left to right direction
actor "He thong (Scheduler)" as SYS
class "NhacNoHoaDonService\nThongBaoService" as C <<control>>
class "HoaDon" as E <<entity>>
actor "Email - SMS" as CH

SYS --> C : dinh ky
C --> E : loc hoa don chua thanh toan du
C --> CH : gui noi dung nhac no
@enduml
