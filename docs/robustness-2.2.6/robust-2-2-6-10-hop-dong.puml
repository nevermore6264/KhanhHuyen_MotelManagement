' 2.2.6.10 — Quan ly hop dong
@startuml robust-2-2-6-10-hop-dong
allowmixing
skinparam shadowing false
skinparam roundcorner 8
skinparam class {
  BackgroundColor<<boundary>> #E8F5E9
  BorderColor<<boundary>> #2E7D32
  BackgroundColor<<control>> #FFFDE7
  BorderColor<<control>> #F9A825
  BackgroundColor<<entity>> #FCE4EC
  BorderColor<<entity>> #C2185B
  FontSize 13
}
skinparam ArrowColor #37474F
skinparam ActorBorderColor #1565C0
skinparam ActorBackgroundColor #E3F2FD

title 2.2.6.10 — Quan ly hop dong
left to right direction
actor "Admin - Staff - Tenant" as U
class "Trang hop dong - hop dong cua toi" as B <<boundary>>
class "HopDongController" as C <<control>>
class "HopDong" as E1 <<entity>>
class "Phong" as E2 <<entity>>
class "KhachThue" as E3 <<entity>>

U --> B
B --> C : "GET POST /api/hop-dong"
C --> E1
C --> E2
C --> E3
@enduml
