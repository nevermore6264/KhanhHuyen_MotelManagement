' 2.2.6.12 — Sinh hoa don tu dong
@startuml robust-2-2-6-12-sinh-hoa-don-tu-dong
allowmixing
skinparam shadowing false
skinparam roundcorner 8
skinparam class {
  BackgroundColor<<boundary>> #E8F5E9
  BorderColor<<boundary>> #2E7D32
  BackgroundColor<<control>> #FFFDE7
  BorderColor<<control>> #F9A825
  BackgroundColor<<entity>> #FCE4EC
  BorderColor<<entity>> #C2185B
  FontSize 13
}
skinparam ArrowColor #37474F
skinparam ActorBorderColor #1565C0
skinparam ActorBackgroundColor #E3F2FD

title 2.2.6.12 — Sinh hoa don tu dong
left to right direction
actor "He thong (Scheduler)" as SYS
actor "Admin (go tay)" as ADM
class "CongViecSinhHoaDon\nHoaDonController" as C <<control>>
class "TinhTienService" as S <<control>>
class "HoaDon" as E1 <<entity>>
class "HopDong\nChiSoDienNuoc\nPhong" as E2 <<entity>>

SYS --> C : @Scheduled cron
ADM --> C : POST sinh hoa don ngay
C --> S : sinhHoaDonChoThang()
S --> E2 : doc hop dong ACTIVE, chi so
S --> E1 : "tao hoac bo qua neu da co"
@enduml
