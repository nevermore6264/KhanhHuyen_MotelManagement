title 2.2.6.29 — Nhan thong bao realtime (STOMP)
left to right direction
actor "Nguoi dung" as U
actor "Broker WebSocket" as WS
class "Trang (STOMP client)" as B <<boundary>>
class "ThongBaoService" as S <<control>>
class "SimpMessagingTemplate" as M <<control>>
class "ThongBao" as E <<entity>>

