' 2.2.6.31 — Staff cap nhat yeu cau ho tro
@startuml robust-2-2-6-31-yeu-cau-ho-tro-cap-nhat
allowmixing
skinparam shadowing false
skinparam roundcorner 8
skinparam class {
  BackgroundColor<<boundary>> #E8F5E9
  BorderColor<<boundary>> #2E7D32
  BackgroundColor<<control>> #FFFDE7
  BorderColor<<control>> #F9A825
  BackgroundColor<<entity>> #FCE4EC
  BorderColor<<entity>> #C2185B
  FontSize 13
}
skinparam ArrowColor #37474F
skinparam ActorBorderColor #1565C0
skinparam ActorBackgroundColor #E3F2FD

title 2.2.6.31 — Xem - cap nhat trang thai yeu cau (Staff)
left to right direction
actor "Admin - Staff" as S
class "Trang yeu cau ho tro" as B <<boundary>>
class "YeuCauHoTroController" as C <<control>>
class "YeuCauHoTroRepository" as R <<control>>
class "YeuCauHoTro" as E <<entity>>

S --> B : xem danh sach
B --> C : "GET /api/yeu-cau-ho-tro"
C --> R : findAll
S --> B : doi trang thai - ghi chu
B --> C : "PUT /api/yeu-cau-ho-tro/{id}"
C --> R : findById, merge, save
R --> E
note right of E
  Gui email phan hoi: logic rieng
  (mail service) neu du an co.
end note
@enduml
