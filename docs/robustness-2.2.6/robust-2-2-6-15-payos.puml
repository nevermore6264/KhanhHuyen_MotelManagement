' 2.2.6.15 — Thanh toan PayOS
@startuml robust-2-2-6-15-payos
allowmixing
skinparam shadowing false
skinparam roundcorner 8
skinparam class {
  BackgroundColor<<boundary>> #E8F5E9
  BorderColor<<boundary>> #2E7D32
  BackgroundColor<<control>> #FFFDE7
  BorderColor<<control>> #F9A825
  BackgroundColor<<entity>> #FCE4EC
  BorderColor<<entity>> #C2185B
  FontSize 13
}
skinparam ArrowColor #37474F
skinparam ActorBorderColor #1565C0
skinparam ActorBackgroundColor #E3F2FD

title 2.2.6.15 — Thanh toan PayOS (link + webhook)
left to right direction
actor "Tenant - Staff" as U
actor "PayOS" as PAY
class "Trang hoa don - thanh toan" as B <<boundary>>
class "ThanhToanController\nPayOSService" as C <<control>>
class "DonHangPayOS\nHoaDon\nThanhToan" as E <<entity>>

U --> B : yeu cau link
B --> C : tao don PayOS
C --> E : luu ma don, hoa_don_id
C --> PAY : "redirect hoac QR"
PAY --> C : webhook xac nhan
C --> E : luu ThanhToan, doi trang thai HoaDon
@enduml
