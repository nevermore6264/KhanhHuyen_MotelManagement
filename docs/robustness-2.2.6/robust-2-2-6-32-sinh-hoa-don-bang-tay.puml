' 2.2.6.32 — Sinh hoa don bang tay (go job som)
@startuml robust-2-2-6-32-sinh-hoa-don-bang-tay
allowmixing
skinparam shadowing false
skinparam roundcorner 8
skinparam class {
  BackgroundColor<<boundary>> #E8F5E9
  BorderColor<<boundary>> #2E7D32
  BackgroundColor<<control>> #FFFDE7
  BorderColor<<control>> #F9A825
  BackgroundColor<<entity>> #FCE4EC
  BorderColor<<entity>> #C2185B
  FontSize 13
}
skinparam ArrowColor #37474F
skinparam ActorBorderColor #1565C0
skinparam ActorBackgroundColor #E3F2FD

title 2.2.6.32 — Sinh hoa don ngay (API go tay)
left to right direction
actor "Admin - Staff" as U
class "Trang hoa don - tong quan" as B <<boundary>>
class "HoaDonController" as HC <<control>>
class "TinhTienService" as TS <<control>>
class "HoaDonRepository" as HR <<control>>
class "HoaDon" as E <<entity>>

U --> B : chon "Sinh hoa don ngay"
B --> HC : "POST /api/hoa-don/sinh"
HC --> TS : sinhHoaDonChoThang(thang truoc)\nsinhHoaDonChoThang(thang hien tai)
TS --> HR : save tung HoaDon moi
HR --> E
HC --> B : JSON so luong da tao
@enduml
