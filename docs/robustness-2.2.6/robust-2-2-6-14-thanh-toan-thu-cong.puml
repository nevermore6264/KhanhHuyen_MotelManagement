' 2.2.6.14 — Thanh toan thu cong
@startuml robust-2-2-6-14-thanh-toan-thu-cong
allowmixing
skinparam shadowing false
skinparam roundcorner 8
skinparam class {
  BackgroundColor<<boundary>> #E8F5E9
  BorderColor<<boundary>> #2E7D32
  BackgroundColor<<control>> #FFFDE7
  BorderColor<<control>> #F9A825
  BackgroundColor<<entity>> #FCE4EC
  BorderColor<<entity>> #C2185B
  FontSize 13
}
skinparam ArrowColor #37474F
skinparam ActorBorderColor #1565C0
skinparam ActorBackgroundColor #E3F2FD

title 2.2.6.14 — Ghi nhan thanh toan thu cong
left to right direction
actor "Admin - Staff" as U
class "Trang thanh toan" as B <<boundary>>
class "ThanhToanController" as C <<control>>
class "ThanhToan" as E1 <<entity>>
class "HoaDon" as E2 <<entity>>

U --> B
B --> C : POST ghi nhan thanh toan
C --> E1 : luu ThanhToan
C --> E2 : cap nhat trang thai HoaDon (neu du tien)
@enduml
