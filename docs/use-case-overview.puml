@startuml
left to right direction
skinparam shadowing false
skinparam packageStyle rectangle
skinparam dpi 240
skinparam defaultFontSize 16
skinparam backgroundColor #FFFFFF

skinparam actor {
  FontSize 18
  FontColor #0F172A
  BackgroundColor #E0F2FE
  BorderColor #0284C7
}

skinparam usecase {
  FontSize 16
  FontColor #0F172A
  BackgroundColor #F8FAFC
  BorderColor #334155
  ArrowColor #475569
}

skinparam packageTitleFontSize 18

title Use Case - Tong quan iTro

actor "Admin (ADMIN)" as ADMIN
actor "Nhan vien (STAFF)" as STAFF
actor "Khach thue (TENANT)" as TENANT
actor "Cổng thanh toán PayOS" as PAYOS
actor "Dịch vụ thông báo realtime" as WS
actor "Kênh Email/SMS" as CHANNEL

rectangle "He thong iTro" {
  (Dang nhap) as UC_LOGIN
  (Dang xuat) as UC_LOGOUT
  (Dat lai mat khau) as UC_PASSWORD_RESET

  (Xem tong quan) as UC_DASHBOARD
  (Xem bao cao/thong ke) as UC_REPORTS

  (Xem/thao tac khu) as UC_AREA
  (Xem/thao tac phong) as UC_ROOM
  (Xem/thao tac khach thue) as UC_TENANT

  (Xem/thao tac hop dong) as UC_CONTRACTS
  (Xem/tai noi dung hop dong) as UC_CONTRACT_DOCS

  (Xem hoa don) as UC_INVOICES_VIEW
  (Sinh hoa don tu dong) as UC_INVOICES_AUTO
  (Gui nhac no hoa don) as UC_INVOICE_REMINDER
  (Xem chi tiet hoa don) as UC_INVOICE_DETAIL

  (Ghi nhan thanh toan thu cong) as UC_PAYMENT_MANUAL
  (Tao link thanh toan PayOS) as UC_PAYOS_LINK
  (Cap nhat trang thai thanh toan) as UC_PAYOS_WEBHOOK
  (Xem lich su thanh toan) as UC_PAYMENT_HISTORY

  (Xem chi so dien/nuoc) as UC_METER_HISTORY
  (Nhap chi so dien/nuoc) as UC_METER_INPUT

  (Thiet lap gia dien/nuoc) as UC_PRICING_SET

  (Xem danh sach thong bao) as UC_NOTIFY_VIEW
  (Danh dau da doc) as UC_NOTIFY_MARK_READ
  (Gui tao thong bao) as UC_NOTIFY_CREATE
  (Nhan thong bao realtime) as UC_NOTIFY_REALTIME

  (Gui yeu cau ho tro) as UC_SUPPORT_CREATE
  (Xem yeu cau ho tro) as UC_SUPPORT_VIEW
  (Cap nhat trang thai/da xu ly) as UC_SUPPORT_UPDATE
  (Gui email phan hoi) as UC_SUPPORT_EMAIL
}

ADMIN --> UC_LOGIN
ADMIN --> UC_LOGOUT
ADMIN --> UC_PASSWORD_RESET
ADMIN --> UC_DASHBOARD
ADMIN --> UC_REPORTS
ADMIN --> UC_AREA
ADMIN --> UC_ROOM
ADMIN --> UC_TENANT
ADMIN --> UC_CONTRACTS
ADMIN --> UC_CONTRACT_DOCS
ADMIN --> UC_INVOICES_VIEW
ADMIN --> UC_INVOICES_AUTO
ADMIN --> UC_INVOICE_REMINDER
ADMIN --> UC_INVOICE_DETAIL
ADMIN --> UC_PAYMENT_MANUAL
ADMIN --> UC_PAYMENT_HISTORY
ADMIN --> UC_METER_HISTORY
ADMIN --> UC_METER_INPUT
ADMIN --> UC_PRICING_SET
ADMIN --> UC_NOTIFY_VIEW
ADMIN --> UC_NOTIFY_MARK_READ
ADMIN --> UC_NOTIFY_CREATE
ADMIN --> UC_SUPPORT_VIEW
ADMIN --> UC_SUPPORT_UPDATE
ADMIN --> UC_SUPPORT_EMAIL

STAFF --> UC_LOGIN
STAFF --> UC_LOGOUT
STAFF --> UC_DASHBOARD
STAFF --> UC_REPORTS
STAFF --> UC_AREA
STAFF --> UC_ROOM
STAFF --> UC_TENANT
STAFF --> UC_CONTRACTS
STAFF --> UC_INVOICES_VIEW
STAFF --> UC_INVOICE_DETAIL
STAFF --> UC_INVOICE_REMINDER
STAFF --> UC_PAYMENT_MANUAL
STAFF --> UC_PAYMENT_HISTORY
STAFF --> UC_METER_HISTORY
STAFF --> UC_METER_INPUT
STAFF --> UC_NOTIFY_VIEW
STAFF --> UC_NOTIFY_MARK_READ
STAFF --> UC_NOTIFY_REALTIME
STAFF --> UC_SUPPORT_VIEW
STAFF --> UC_SUPPORT_UPDATE
STAFF --> UC_SUPPORT_EMAIL

TENANT --> UC_LOGIN
TENANT --> UC_LOGOUT
TENANT --> UC_DASHBOARD
TENANT --> UC_CONTRACTS
TENANT --> UC_CONTRACT_DOCS
TENANT --> UC_INVOICES_VIEW
TENANT --> UC_INVOICE_DETAIL
TENANT --> UC_PAYMENT_HISTORY
TENANT --> UC_SUPPORT_CREATE
TENANT --> UC_NOTIFY_VIEW
TENANT --> UC_NOTIFY_MARK_READ
TENANT --> UC_NOTIFY_REALTIME

PAYOS --> UC_PAYOS_WEBHOOK
WS --> UC_NOTIFY_REALTIME
CHANNEL --> UC_INVOICE_REMINDER
CHANNEL --> UC_SUPPORT_EMAIL

UC_PAYOS_LINK ..> PAYOS : <<include>>
UC_INVOICE_REMINDER ..> UC_INVOICE_DETAIL : <<include>>
UC_METER_INPUT ..> UC_INVOICES_AUTO : <<include>>

@enduml

