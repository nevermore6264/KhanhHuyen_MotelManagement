@startuml
skinparam shadowing false
skinparam ActivityBackgroundColor #F8FAFC
skinparam ActivityBorderColor #334155
skinparam ArrowColor #334155

title Hình 2.8 — Quy trình cấu hình danh mục: khu vực, phòng, bảng giá dịch vụ

|Quản trị / Nhân viên|
start
partition "Khu vực" {
  :Khai báo / sửa / xóa khu vực\n(theo quy tắc nghiệp vụ);
}

partition "Phòng" {
  :Thêm phòng, gán khu,\ntrạng thái, giá thuê hiện tại;
  :Cập nhật khi đổi giá\nhoặc bảo trì phòng;
}

partition "Bảng giá điện — nước" {
  :Thiết lập đơn giá mới,\nngày hiệu lực;
}

|Hệ thống|
:Lưu dữ liệu phục vụ\ntính hóa đơn và chỉ số;

|Quản trị / Nhân viên|
:Xem danh sách / lọc\nđể vận hành hằng ngày;
stop

note right
  API: /api/khu-vuc, /api/phong, /api/bang-gia
  Một số thao tác chỉ ADMIN.
end note

@enduml
