@startuml
skinparam shadowing false
skinparam ActivityBackgroundColor #F8FAFC
skinparam ActivityBorderColor #334155
skinparam ArrowColor #334155

title Hình 2.5 — Quy trình xác thực và quản lý phiên đăng nhập

|Người dùng|
start

if (Cần tài khoản mới?) then (có — đăng ký)
  :Gửi thông tin đăng ký;
  |Hệ thống|
  :Kiểm tra trùng tài khoản,\ntạo người dùng, mã hóa mật khẩu;
  |Người dùng|
endif

:Đăng nhập (tên đăng nhập, mật khẩu);
|Hệ thống|
if (Hợp lệ và tài khoản đã kích hoạt?) then (có)
  :Cấp token (JWT),\nthiết lập phiên làm việc;
  |Người dùng|
  :Truy cập chức năng\ntheo vai trò;
else (không)
  |Người dùng|
  :Nhận thông báo lỗi;
endif

|Người dùng|
if (Quên mật khẩu?) then (có)
  |Hệ thống|
  :Tạo phiếu đặt lại mật khẩu,\ngửi email hoặc trả link;
  |Người dùng|
  :Đặt mật khẩu mới\nqua token hợp lệ;
endif

stop

@enduml
