@startuml
skinparam shadowing false
skinparam ActivityBackgroundColor #F8FAFC
skinparam ActivityBorderColor #334155
skinparam ArrowColor #334155

title Hình 2.7 — Quy trình quản lý người dùng (quản trị viên)

|Quản trị viên|
start
:Vào mục Quản lý người dùng;

if (Thao tác?) then (Tạo mới)
  :Nhập tài khoản, mật khẩu,\nvai trò (ADMIN/STAFF/TENANT);
  :Lưu; gắn khách thuê\n(nếu tạo TENANT);
elseif (Sửa) then
  :Cập nhật họ tên, SĐT,\nliên kết khách, đổi mật khẩu;
elseif (Khóa / Mở khóa) then
  :Chuyển trạng thái\nkích hoạt tài khoản;
else (Gắn khách)
  :Chọn khách có sẵn\nhoặc tạo khách mới rồi gắn;
endif

|Hệ thống|
:Lưu thay đổi vào CSDL;

|Quản trị viên|
:Xác nhận danh sách\nđã cập nhật;
stop

note right
  Nhân viên thường chỉ xem\ndanh sách, không chỉnh sửa\n(theo phân quyền ứng dụng).
end note

@enduml
